        </mxCell>
        <mxCell id="std3" value="&lt;b&gt;3. Progressive Disclosure&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:8px;color:#555&#39;&gt;SKILL.md ≤500 lines — overflow to references/, assets/, scripts/&lt;/font&gt;" style="fontColor=#1A2B3C;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=6;fontSize=9;" parent="1" vertex="1">
