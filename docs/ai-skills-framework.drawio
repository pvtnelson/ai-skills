        <mxCell id="std1" value="&lt;b&gt;1. Step 0-N Protocol&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:8px;color:#555&#39;&gt;Step 0: logging → Step 1: gate → Step 2: core → Step N: output&lt;/font&gt;" style="fontColor=#1A2B3C;rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=6;fontSize=9;" parent="1" vertex="1">
